<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <%# Branded Page Header %>
    <div class="mb-16 text-center md:text-left">
      <h1 class="text-5xl font-black text-[#01003d] uppercase tracking-tighter leading-none">
        Membership <span class="text-transparent" style="-webkit-text-stroke: 1px #01003d;">Tiers</span>
      </h1>
      <div class="w-16 h-1 bg-[#01003d] mt-4 rounded-full mx-auto md:mx-0"></div>
      <p class="text-gray-500 mt-6 font-medium uppercase tracking-[0.2em] text-xs">Unlock elite performance tracking and recruitment tools</p>
    </div>

    <% if current_user.nil? || current_user.plan.nil? %>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <% @subscription_plans.each_with_index do |plan, index| %>
            <% is_featured = index == 1 %>
            
            <div class="relative flex flex-col rounded-[2.5rem] border-2 <%= is_featured ? 'border-[#01003d] shadow-2xl scale-105 z-10' : 'border-gray-100 shadow-sm' %> bg-white p-10 transition-all duration-500 hover:shadow-blue-900/10">
                
                <% if is_featured %>
                    <div class="absolute top-0 -translate-y-1/2 left-1/2 -translate-x-1/2 bg-[#01003d] text-white text-[10px] font-black uppercase tracking-[0.25em] px-6 py-2 rounded-full shadow-lg">
                        Elite Choice
                    </div>
                <% end %>

                <div class="mb-8">
                    <h2 class="text-2xl font-black text-[#01003d] uppercase tracking-tighter">
                        <%= plan.name %>
                    </h2>
                    <div class="h-1 w-8 bg-blue-500/30 mt-2"></div>
                </div>

                <div class="mb-10">
                    <div class="flex items-baseline gap-1">
                        <span class="text-4xl font-black tracking-tighter text-[#01003d]">
                            <%= number_to_currency(plan.amount / 100.0, unit: plan.currency == 'GBP' ? '£' : plan.currency) %>
                        </span>
                        <span class="text-sm font-black text-gray-400 uppercase tracking-widest">
                            /<%= plan.interval_unit %>
                        </span>
                    </div>
                    <p class="text-[10px] font-bold text-gray-400 mt-2 uppercase tracking-widest leading-relaxed">Access to Chambers Performance Hub</p>
                </div>

                <%# Scout-Style Feature List %>
                <ul class="mb-10 space-y-5 flex-1">
                    <% [
                        { icon: 'monitoring', text: 'Core Performance Analytics' },
                        { icon: 'verified', text: 'Verified Athlete Profile' },
                        { icon: 'support_agent', text: 'Priority Performance Support' },
                        { icon: 'history', text: 'Cancel Membership Anytime' }
                    ].each do |feature| %>
                        <li class="flex items-center gap-3">
                            <span class="material-symbols-outlined !text-[20px] <%= is_featured ? 'text-blue-600' : 'text-emerald-500' %>">
                                <%= feature[:icon] %>
                            </span>
                            <span class="text-xs font-bold text-gray-600 uppercase tracking-wide"><%= feature[:text] %></span>
                        </li>
                    <% end %>
                </ul>

                <%= form_with url: '/payments', method: :post, data: { turbo: false }, class: "mt-auto" do |f| %>
                    <%= f.hidden_field :plan_id, value: plan.id %>
                    <%= f.hidden_field :athlete, value: params[:user_id] %>
                    <button type="submit" class="<%= is_featured ? 'btn-brand-primary' : 'w-full py-4 px-6 font-black text-xs uppercase tracking-[0.2em] bg-gray-50 text-gray-400 hover:bg-[#01003d] hover:text-white border border-gray-100 transition-all duration-300' %>">
                        Select Contract
                    </button>
                <% end %>
            </div>
        <% end %>
    </div>

    <%# Security Footer %>
    <div class="mt-20 pt-10 border-t border-gray-100 flex flex-col items-center">
        <div class="flex items-center gap-3 px-6 py-2 bg-gray-50 rounded-full border border-gray-100 mb-8">
            <span class="material-symbols-outlined text-gray-400 text-sm">lock</span>
            <span class="text-[10px] font-black uppercase tracking-widest text-gray-400">Secure 256-bit SSL encrypted & PCI compliant</span>
        </div>
        
        <div class="flex gap-8 opacity-30 grayscale transition-all hover:opacity-100 hover:grayscale-0">
            <%= image_tag "visa_logo.svg", alt: "Visa", class: "h-5" %>
            <%= image_tag "mastercard_logo.svg", alt: "Mastercard", class: "h-5" %>
            <%= image_tag "stripe_logo.svg", alt: "Stripe", class: "h-8" %>
        </div>
    </div>
    <% end %>
</section>