<% input_style = "w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block p-2.5" %>

<%= form_with model: @taster_booking, url: admin_taster_booking_path(@taster_booking), local: true do |form| %>
<div class="max-w-5xl mx-auto p-6 bg-white rounded-lg shadow-md border border-gray-200 my-4">
    <div class="flex justify-between items-center mb-6 border-b pb-4">
        <h2 class="text-2xl font-bold text-gray-800 uppercase tracking-tight">Taster Session Booking</h2>
        <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-gray-500 uppercase">Booking ID:</span>
            <span class="px-3 py-1 bg-gray-100 rounded-full text-xs font-mono font-bold text-gray-600">#<%= @taster_booking.id %></span>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        <div class="lg:col-span-2 space-y-8">

            <section>
                <h3 class="text-sm font-bold text-blue-600 uppercase mb-4 flex items-center">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                    </svg>
                    Primary Contact Details
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">First Name</label>
                        <%= form.text_field :first_name, class: input_style %>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Last Name</label>
                        <%= form.text_field :last_name, class: input_style %>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Email Address</label>
                        <%= form.email_field :email, class: input_style %>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Phone Number</label>
                        <%= form.telephone_field :phone, class: input_style %>
                    </div>
                </div>
            </section>

            <section class="bg-blue-50/50 p-4 rounded-xl border border-blue-100">
                <h3 class="text-sm font-bold text-gray-700 uppercase mb-4">Athlete Information</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="md:col-span-2">
                        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Athlete Full Name (If different from contact)</label>
                        <%= form.text_field :athlete_full_name, class: input_style, placeholder: "e.g. Junior Smith" %>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Athlete Birth Date</label>
                        <%= form.date_field :birth_date, class: input_style %>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Emergency Contact Phone</label>
                        <%= form.telephone_field :emergency_contact_phone, class: input_style %>
                    </div>
                </div>
            </section>

            <section>
                <h3 class="text-sm font-bold text-gray-700 uppercase mb-4">Health & Medical</h3>
                <div class="space-y-4">
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Health Issues / Injuries</label>
                        <%= form.text_area :health_issues, rows: 2, class: input_style, placeholder: "List any allergies or medical conditions..." %>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Internal Admin Notes</label>
                        <%= form.text_area :internal_notes, rows: 2, class: "#{input_style} bg-yellow-50/50 border-yellow-200", placeholder: "Staff only: assessment results, coach feedback..." %>
                    </div>
                </div>
            </section>
        </div>

        <div class="space-y-6">
            <div class="bg-gray-50 p-6 rounded-xl border border-gray-200 shadow-sm">
                <h3 class="text-sm font-bold text-gray-700 uppercase mb-4">Session Logistics</h3>

                <div class="space-y-4">
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Booking Status</label>
                        <%= form.select :status, 
                TasterSessionBooking.statuses.keys.map { |s| [s.humanize, s] }, 
                {}, 
                class: "w-full bg-white border border-gray-300 text-gray-900 text-sm rounded-lg p-2.5 font-bold capitalize" %>
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Session Date</label>
                        <%= form.date_field :taster_session_date, class: input_style %>
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Location / Venue</label>
                        <%= form.text_field :location, class: input_style, placeholder: "Main Hall / Pitch 1" %>
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Source (Marketing)</label>
                        <%= form.select :referral_source, options_for_select(['Instagram', 'Facebook', 'Friend', 'Website'], @taster_booking.referral_source), { include_blank: "Select Source" }, class: input_style %>
                    </div>
                </div>
            </div>

            <div class="p-6 bg-white border border-gray-200 rounded-xl">
                <h3 class="text-xs font-bold text-gray-400 uppercase mb-4 tracking-widest">Compliance (This is filed by user)*</h3>
                <div class="space-y-4">
                    <div class="flex items-center">
                        <%= form.check_box :registration_confirmation, class: "w-5 h-5 text-blue-600 border-gray-300 rounded focus:ring-blue-500" %>
                        <label class="ml-3 text-sm font-medium text-gray-700">Confirmed Register</label>
                    </div>

                    <div class="flex items-center">
                        <%= form.check_box :policy_agreement, class: "w-5 h-5 text-blue-600 border-gray-300 rounded focus:ring-blue-500" %>
                        <label class="ml-3 text-sm font-medium text-gray-700">Policy Signed</label>
                    </div>
                </div>
            </div>
            <div class="h-12 flex flex-col justify-center">
                <label class="block text-xs font-semibold text-gray-500 uppercase">Reminder Status</label>
                <div class="flex items-center gap-2 mt-1">
                    <% if @taster_booking.reminder_sent_at.nil? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                        <span class="w-2 h-2 mr-1.5 bg-gray-400 rounded-full"></span>
                        Not Reminded
                    </span>
                    <% else %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                        <span class="w-2 h-2 mr-1.5 bg-green-500 rounded-full"></span>
                        Sent: <%= @taster_booking.reminder_sent_at.strftime("%d %b, %H:%M") %>
                    </span>
                    <% end %>
                </div>
            </div>

            <div class="mt-2">
                <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Manual Reminder Log</label>
                <%= form.datetime_field :reminder_sent_at, class: input_style %>
            </div>
        </div>
    </div>

    <div class="mt-10 pt-6 border-t flex flex-col md:flex-row justify-between items-center gap-4">
        <div class="text-xs text-gray-400 italic">
            Last updated: <%= @taster_booking.updated_at.strftime("%B %d, %Y at %H:%M") %>
        </div>
        <div class="flex space-x-3 w-full md:w-auto">
            <%= link_to "Cancel", admin_taster_booking_index_path, class: "w-1/2 md:w-auto text-center px-6 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50" %>
            <%= form.submit "Update Booking", class: "w-1/2 md:w-auto btn", data: { turbo_submits_with: "Updating..." } %>
        </div>
    </div>
</div>
<% end %>