<div class="min-h-screen p-4 md:p-8">

  <%= render 'shared/page_header', title: 'Parent Dashboard', description: "Stay connected with your athlete's professional journey", icon: "family" %>

  <div class="flex items-center gap-2 mb-6">
    <div class="h-1 w-8 bg-[#01003d] rounded-full"></div>
    <h2 class="text-xs font-black uppercase tracking-[0.2em] text-gray-400 dark:text-gray-100">Accounts</h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
    <% if !@children.nil? %>
      <%= render 'parents/dashboard/partials/child_overview_cards', children: @children %>
    <% end %>

    <div class="group bg-white p-8 border-2 border-dashed border-gray-200 hover:border-[#01003d] hover:bg-blue-50/30 transition-all duration-300 flex flex-col items-center justify-center relative overflow-hidden">
      <div class="w-16 h-16 rounded-full bg-gray-50 flex items-center justify-center text-gray-400 group-hover:bg-[#01003d] group-hover:text-white transition-all duration-300 mb-4 shadow-sm">
        <span class="material-symbols-outlined text-3xl">add</span>
      </div>
      <h3 class="font-bold text-[#01003d] mb-1">Add Child Athlete</h3>
      <p class="text-xs text-gray-500 text-center mb-6 max-w-[200px] leading-relaxed">
        Track multiple athlete profiles and progress in one ecosystem.
      </p>
      
      <%= link_to "/accounts/add_child", class:"btn-brand-primary flex items-center gap-2 py-3 px-6 text-xs w-full sm:w-auto" do %>
        <span class="material-symbols-outlined text-sm">person_add</span>
        Register Child
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 hidden">
    
    <div id="progress-timeline-container" 
         data-controller="child-selector" 
         class="lg:col-span-2 bg-white p-6 shadow-sm border border-gray-100"
         data-child-selector-url-value="<%= select_child_parents_dashboard_index_path(child_id: ':child_id') %>">
      
      <div class="flex items-center justify-between mb-8">
        <h3 class="font-black uppercase tracking-widest text-[#01003d] text-sm">Development Timeline</h3>
      </div>

      <%= render 'parents/dashboard/partials/progress_timeline', 
            milestones: @milestones || [], 
            children: @children, 
            selected_child: @selected_child %>
    </div>

    <div class="space-y-8">
      <div class="hidden bg-white  p-1 shadow-sm border border-gray-100 overflow-hidden">
        <%= render 'parents/dashboard/partials/messages_feedback', coach_feedback: @coach_feedback || [] %>
      </div>

      <div class="bg-white p-1 shadow-sm border border-gray-100 overflow-hidden">
        <%= render 'parents/dashboard/partials/upcoming_events', upcoming_events: @upcoming_events || [] %>
      </div>

      <div class="bg-white p-1 shadow-sm border border-gray-100 overflow-hidden">
        <%= render 'parents/dashboard/partials/attendance_notification', children_attendances: @children_attendances%>
      </div>
    </div>
  </div>
</div>