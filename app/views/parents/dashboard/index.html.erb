<div class="max-w-7xl mx-auto  min-h-screen py-2 px-4 md:px-8">
  <% render 'shared/page_header', title: 'Home', description: "Stay connected with your athlete's professional journey", icon: "family" %>

  <div class="flex items-center gap-2 m-6">
    <div class="h-1 w-8 bg-[#01003d] rounded-full"></div>
    <h2 class="text-xs font-black uppercase tracking-[0.2em] text-gray-400 dark:text-gray-100">Accounts</h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
    <% if !@children.nil? %>
      <%= render 'parents/dashboard/partials/child_overview_cards', children: @children %>
    <% end %>

    <div class="group bg-white p-8 border-2 border-dashed border-gray-200 hover:border-[#01003d] hover:bg-blue-50/30 transition-all duration-300 flex flex-col items-center justify-center relative overflow-hidden">
      <div class="w-16 h-16 rounded-full bg-gray-50 flex items-center justify-center text-gray-400 group-hover:bg-[#01003d] group-hover:text-white transition-all duration-300 mb-4 shadow-sm">
        <span class="material-symbols-outlined text-3xl">add</span>
      </div>
      <h3 class="font-bold text-[#01003d] mb-1">Add Child Athlete</h3>
      <p class="text-xs text-gray-500 text-center mb-6 max-w-[200px] leading-relaxed">
        Track multiple athlete profiles and progress in one ecosystem.
      </p>
      
      <%= link_to "/accounts/new", class:"btn-brand-primary flex items-center gap-2 py-3 px-6 text-xs w-full sm:w-auto" do %>
        <span class="material-symbols-outlined text-sm">person_add</span>
        Register Child
      <% end %>
    </div>
  </div>

</div>