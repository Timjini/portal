<div class="bg-white dark:bg-slate-900 rounded-3xl shadow-xl shadow-blue-900/5 overflow-hidden border border-gray-100 dark:border-gray-800 hover:shadow-2xl transition-all duration-500 group flex flex-col h-full">
  
  <div class="relative h-52 overflow-hidden bg-[#01003d]">
    <% if !competition.competition_thumbnail.nil? %>
      <%= image_tag competition.competition_thumbnail, class: "w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-80" %>
    <% else %>
      <div class="w-full h-full flex items-center justify-center">
        <span class="material-symbols-outlined text-white/10 text-8xl">trophy</span>
      </div>
    <% end %>

    <div class="absolute top-4 left-4 bg-white/95 backdrop-blur px-3 py-1.5 rounded-xl shadow-lg flex flex-col items-center min-w-[50px]">
      <span class="text-[10px] font-black uppercase tracking-tighter text-gray-400 leading-none">
        <%= competition.date.strftime("%b") %>
      </span>
      <span class="text-lg font-black text-[#01003d] leading-none">
        <%= competition.date.strftime("%d") %>
      </span>
    </div>

    <div class="absolute top-4 right-4">
      <%= status_chip(competition) %> </div>

    <div class="absolute bottom-0 inset-x-0 p-6 bg-gradient-to-t from-[#01003d] to-transparent">
      <h3 class="text-xl font-black text-white uppercase tracking-tighter leading-tight">
        <%= competition.title %>
      </h3>
    </div>
  </div>

  <div class="p-6 flex flex-col flex-1">
    
    <div class="flex items-center gap-6 mb-6">
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-blue-500 !text-[20px]">group</span>
        <div class="flex flex-col">
          <span class="text-[14px] font-black text-[#01003d] dark:text-white leading-none"><%= competition.participants %></span>
          <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Athletes</span>
        </div>
      </div>
      <div class="h-8 w-[1px] bg-gray-100"></div>
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-emerald-500 !text-[20px]">calendar_today</span>
        <div class="flex flex-col">
          <span class="text-[14px] font-black text-[#01003d] dark:text-white leading-none"><%= competition.date.year %></span>
          <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Season</span>
        </div>
      </div>
    </div>

    <div class="flex-1">
      <% if competition.description.present? %>
        <p class="text-gray-500 text-sm leading-relaxed line-clamp-2 mb-6">
          <%= competition.description %>
        </p>
      <% else %>
        <p class="text-gray-400 text-xs italic mb-6">No event documentation available.</p>
      <% end %>
    </div>

    <div class="space-y-3">
      <%= link_to competition.link, target: "_blank", class: "group/btn w-full flex items-center justify-center gap-2 py-3 px-4 rounded-xl bg-gray-50 dark:bg-slate-800 border border-gray-100 dark:border-gray-700 text-[#01003d] dark:text-white font-black text-xs uppercase tracking-widest hover:bg-[#01003d] hover:text-white transition-all duration-300" do %>
        <span class="material-symbols-outlined text-[18px]">open_in_new</span>
        Official Registration
      <% end %>

      <div class="pt-3 border-t border-gray-100 dark:border-gray-800">
        <% if competition.subscribed?(current_user) %>
          <div class="flex items-center justify-center gap-2 py-3 w-full bg-emerald-50 text-emerald-600 rounded-xl font-black text-xs uppercase">
            <span class="material-symbols-outlined text-[18px]">verified</span>
            Participation Confirmed
          </div>
        <% elsif ["coach", "admin"].include?(current_user.role) %>
          <div class="grid grid-cols-3 gap-2">
            <%= link_to competition_path(competition), class: "p-2 bg-gray-50 rounded-lg text-gray-400 hover:text-[#01003d] flex items-center justify-center" do %>
              <span class="material-symbols-outlined">visibility</span>
            <% end %>
            <%= link_to edit_competition_path(competition), class: "p-2 bg-blue-50 rounded-lg text-blue-400 hover:text-blue-600 flex items-center justify-center" do %>
              <span class="material-symbols-outlined">edit</span>
            <% end %>
            <%= link_to competition_path(competition), 
                data: { turbo_method: :delete, turbo_confirm: "Remove this event?" }, 
                class: "p-2 bg-red-50 rounded-lg text-red-400 hover:text-red-600 flex items-center justify-center" do %>
              <span class="material-symbols-outlined">delete</span>
            <% end %>
          </div>
        <% else %>
          <%= form_with model: [competition, CompetitionEntry.new], class: "w-full" do |f| %>
            <%= f.submit "Declare Participation", 
                class: "btn-brand-primary w-full py-3 shadow-lg shadow-blue-900/10", 
                data: { turbo_confirm: 'Did you register on the external link first?', turbo_submits_with: 'Syncing...' } %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>