<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end mb-10 gap-6">
   <%= render 'shared/page_header', title:"Competition Center", description: "Manage events and track athlete participation", icon:'calendar' %>
    <% if @current_user.role == 'coach' || @current_user.role == 'admin' %>
      <div class="flex-shrink-0">
        <%= link_to new_competition_path, class: "btn-brand-primary flex items-center gap-2 py-3 px-6 shadow-xl shadow-blue-900/20" do %>
          <span class="material-symbols-outlined text-[20px]">add_circle</span>
          New Competition
        <% end %>
      </div>
    <% end %>
  </div>

  <% if notice.present? %>
    <div class="mb-8 rounded-2xl bg-emerald-50 border border-emerald-100 p-4 flex items-center gap-3 animate-in fade-in slide-in-from-top-2">
      <span class="material-symbols-outlined text-emerald-600">check_circle</span>
      <p class="text-emerald-800 text-sm font-bold uppercase tracking-wide"><%= notice %></p>
    </div>
  <% end %>

  <% if @competitions.any? %>
    <div class="mb-10 relative overflow-hidden bg-[#01003d] rounded-3xl p-6 md:p-8 shadow-2xl">
      <div class="absolute top-0 right-0 w-32 h-32 bg-white/5 rounded-full -mr-16 -mt-16"></div>
      
      <div class="relative flex flex-col md:flex-row items-center gap-6">
        <div class="flex-shrink-0 w-14 h-14 bg-white/10 rounded-2xl flex items-center justify-center backdrop-blur-md border border-white/20">
          <span class="material-symbols-outlined text-white text-3xl">info</span>
        </div>
        <div class="flex-1 text-center md:text-left">
          <h3 class="text-xs font-black uppercase tracking-[0.2em] text-blue-300 mb-1">Participation Protocol</h3>
          <p class="text-white text-sm md:text-base leading-relaxed font-medium">
            Review event <span class="text-blue-300 font-black italic underline decoration-2 underline-offset-4">Details</span>, submit your entry, then select <span class="text-blue-300 font-black italic underline decoration-2 underline-offset-4">Participate</span> to sync with Chambers for Sport.
          </p>
        </div>
      </div>
    </div>

    <div id="competitions" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% @competitions.each do |competition| %>
        <div class="transition-transform duration-300 hover:-translate-y-2">
          <%= render competition %>
        </div>
      <% end %>
    </div>

  <% else %>
    <div class="text-center py-24 bg-white dark:bg-transparent rounded-3xl border border-gray-100 shadow-sm flex flex-col items-center">
      <div class="w-24 h-24 mb-6 rounded-full bg-gray-50 flex items-center justify-center text-gray-300">
        <span class="material-symbols-outlined !text-[48px]">event_busy</span>
      </div>
      <h3 class="text-2xl font-black text-[#01003d] uppercase tracking-tighter mb-2 dark:text-gray-400">No active competitions</h3>
      <p class="text-gray-500 max-w-sm mx-auto mb-8 font-medium">
        The competition circuit is currently clear. Check back later for upcoming athlete opportunities.
      </p>
      
      <% if @current_user.role == 'coach' || @current_user.role == 'admin' %>
        <div class="flex flex-col sm:flex-row gap-4">
          <%= link_to "New Competition", new_competition_path, class: "btn-brand-primary px-8" %>
          <button class="px-8 py-3 rounded-xl border border-gray-200 text-sm font-bold text-gray-600 hover:bg-gray-50 transition-colors">
            Learn More
          </button>
        </div>
      <% end %>
    </div>
  <% end %>
</div>