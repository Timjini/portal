<div data-controller="mobile-menu" class="flex flex-col flex-wrap align-center gap-4 lg:hidden mb-24">
  <div class="absolute top-4 left-4 z-50">
    <a href="/">
      <%= image_tag('cfs-dark.png', alt: "Logo", class: 'h-24 w-auto') %>
    </a>
  </div>

  <button 
    data-action="click->mobile-menu#toggle"
    class="hamburger-button p-3 rounded-xl focus:outline-none focus:ring-2 focus:ring-offset-2 hover:bg-gray-100 transition-all duration-200 absolute top-3 right-3 z-50 shadow-sm border border-gray-100 bg-white"
    style="--tw-ring-color: #01003d;"
  >
    <div class="flex flex-col items-center justify-center w-6 h-6">
      <div class="w-6 h-0.5 rounded-full transition-all duration-300 mb-1.5 origin-center" 
          style="background-color: #01003d;" data-mobile-menu-target="bar1"></div>
      <div class="w-4 h-0.5 rounded-full transition-all duration-300 mb-1.5 self-end" 
          style="background-color: #01003d;" data-mobile-menu-target="bar2"></div>
      <div class="w-6 h-0.5 rounded-full transition-all duration-300 origin-center" 
          style="background-color: #01003d;" data-mobile-menu-target="bar3"></div>
    </div>
  </button>

  <div 
    data-mobile-menu-target="menu"
    class="hidden fixed inset-0 z-40 transform translate-x-full transition-transform duration-300 ease-in-out flex flex-col p-6 bg-white"
  >
    <div class="mt-20 overflow-y-auto flex-1">
      <p class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 mb-6 px-2">Main Navigation</p>
      
      <div class="space-y-2">
        <% nav_items_for_current_user.each do |item| %>
          <div class="nav-group">
            <div class="flex items-center gap-3 py-3 px-4 rounded-2xl transition-all
              <%= request.path == item[:path] ? 'bg-[#01003d] text-white shadow-lg' : 'text-gray-600 active:bg-gray-100' %>">
              
              <%= link_to item[:path], class: "flex items-center gap-4 flex-1" do %>
                <span class="material-symbols-outlined text-[24px]">
                  <%= render partial: "icons/#{item[:icon]}" %>
                </span>
                <span class="text-base font-bold tracking-tight"><%= item[:name] %></span>
                
                <% if item[:tag] %>
                  <span class="inline-flex items-center rounded-full bg-blue-500 px-2 py-0.5 text-[9px] font-black uppercase text-white">
                    <%= item[:tag] %>
                  </span>
                <% end %>
              <% end %>

              <% if item[:children] %>
                <span class="material-symbols-outlined arrow transition-transform cursor-pointer"
                   onclick="this.closest('.nav-group').querySelector('.children').classList.toggle('hidden'); this.classList.toggle('rotate-90')">
                  expand_more
                </span>
              <% end %>
            </div>

            <% if item[:children] %>
              <div class="children ml-10 flex-col space-y-1 mt-2 hidden border-l-2 border-gray-100">
                <% item[:children].each do |child| %>
                  <%= link_to child[:path], class: "py-3 px-4 text-gray-500 font-medium text-sm block" do %>
                    <%= child[:name] %>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="pt-6 border-t border-gray-100 mt-auto pb-8">
      <a href="/users/<%= current_user.id %>" class="flex items-center gap-4 mb-6 p-3 rounded-2xl bg-gray-50">
         <div class="relative">
            <% if current_user.avatar_thumbnail.present? %>
              <%= image_tag(current_user.avatar_thumbnail, class: "w-12 h-12 rounded-full object-cover ring-2 ring-white shadow-sm") %>
            <% else %>
              <div class="w-12 h-12 rounded-full bg-[#01003d] text-white flex items-center justify-center font-bold">
                <%= current_user.first_name[0] %>
              </div>
            <% end %>
         </div>
         <div class="user-info">
            <div class="text-base font-bold text-gray-800"><%= current_user.full_name %></div>
            <div class="text-xs font-bold text-gray-400 uppercase tracking-widest"><%= current_user.role %></div>
         </div>
      </a>

      <%= button_to destroy_user_session_path, method: :delete, class: "flex w-full items-center justify-center gap-2 py-4 px-4 rounded-2xl bg-red-50 text-red-600 font-bold text-sm transition-active active:scale-95" do %>
         <span class="material-symbols-outlined text-[20px]">logout</span>
         Logout from Platform
      <% end %>
    </div>
  </div>
</div>

<style>
  /* Ensure the menu is strictly hidden on desktop */
  @media (min-width: 1024px) {
    [data-controller="mobile-menu"] {
      display: none !important;
    }
  }

  /* Hamburger Animation logic (managed by your Stimulus controller) */
  .mobile-menu-open [data-mobile-menu-target="bar1"] { transform: translateY(8px) rotate(45deg); }
  .mobile-menu-open [data-mobile-menu-target="bar2"] { opacity: 0; }
  .mobile-menu-open [data-mobile-menu-target="bar3"] { transform: translateY(-8px) rotate(-45deg); }
</style>