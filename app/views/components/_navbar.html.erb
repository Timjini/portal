<aside id="sidebar"
   aria-label="Main sidebar"
   class="hidden lg:flex fixed left-0 top-0 h-screen w-60 flex-col pt-8 pb-6 px-4 shadow-2xl z-20 overflow-y-auto border-r border-gray-100"
   >
   <div class="mb-10 px-2">
      <a class="flex items-center gap-3" href="/">
         <%= image_tag('cfs-dark.png', alt: "Logo", class: 'h-24 w-auto hover:opacity-80 transition-opacity') %>
      </a>
   </div>

   <nav class="flex-1 flex flex-col space-y-1" role="navigation" aria-label="Primary">
      <% nav_items_for_current_user.each do |item| %>
      <div class="nav-group">
         <div
            class="group flex items-center gap-3 py-2.5 px-3 transition-all nav_item
            <%= request.path == item[:path] ? 'bg-[#01003d] text-white shadow-lg shadow-blue-900/20' : 'text-gray-500 hover:bg-gray-100/80 hover:text-[#01003d]' %>">
            
            <%= link_to item[:path], class: "flex items-center gap-3 flex-1" do %>
               <span class="material-symbols-outlined text-[22px] <%= request.path == item[:path] ? 'text-white' : 'text-gray-400 group-hover:text-[#01003d]' %>">
                  <%= render partial: "icons/#{item[:icon]}" %>
               </span>
               <span class="text-sm font-bold tracking-tight"><%= item[:name] %></span>
               
               <% if item[:tag] %>
                  <span class="ml-auto inline-flex items-center rounded-full bg-blue-500 px-2 py-0.5 text-[10px] font-black uppercase tracking-widest text-white animate-pulse">
                     <%= item[:tag] %>
                  </span>
               <% end %>
            <% end %>

            <% if item[:children] %>
               <span class="ml-auto material-symbols-outlined arrow transition-transform duration-200 cursor-pointer text-gray-400 group-hover:text-inherit"
                  onclick="this.closest('.nav-group').querySelector('.children').classList.toggle('hidden'); this.classList.toggle('rotate-90')">
                  keyboard_arrow_right
               </span>
            <% end %>
         </div>

         <% if item[:children] %>
         <div class="children ml-9 flex-col space-y-1 mt-1 hidden border-l-2 border-gray-100">
            <% item[:children].each do |child| %>
            <%= link_to child[:path],
               class: "group flex items-center gap-3 py-2 px-4 transition-all rounded-r-lg #{request.path == child[:path] ? 'text-[#01003d] font-bold bg-blue-50/50' : 'text-gray-500 hover:text-[#01003d] hover:bg-gray-50'}" do %>
               <span class="text-sm"><%= child[:name] %></span>
            <% end %>
            <% end %>
         </div>
         <% end %>
      </div>
      <% end %>
   </nav>

   <div class="sidebar-footer pt-6 border-t border-gray-100 mt-auto">
      <a href="/users/<%= current_user.id %>" class="flex items-center gap-3 mb-4 p-2 hover:bg-gray-100 transition-all border border-transparent hover:border-gray-200">
         <div class="relative">
            <% if current_user.avatar_thumbnail.present? %>
               <%= image_tag(current_user.avatar_thumbnail, alt: "Avatar", class: "w-9 h-9 rounded-full shadow-md object-cover ring-2 ring-white") %>
            <% else %>
               <div class="w-9 h-9 rounded-full bg-gray-200 flex items-center justify-center text-[#01003d] font-bold text-xs">
                  <%= current_user.first_name[0] %>
               </div>
            <% end %>
            <div class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-green-500 border-2 border-white rounded-full"></div>
         </div>
         <div class="user-info">
            <div class="text-sm font-bold text-gray-800 tracking-tight"><%= current_user.full_name %></div>
            <div class="text-[10px] font-bold text-gray-400 uppercase tracking-widest"><%= current_user.role %></div>
         </div>
      </a>

      <%= button_to destroy_user_session_path, method: :delete, class: "group flex w-full items-center gap-3 py-2.5 px-3 rounded-xl hover:bg-red-50 transition-all" do %>
         <span class="material-symbols-outlined text-gray-400 group-hover:text-red-500 text-[20px]">logout</span>
         <span class="text-sm font-bold text-gray-500 group-hover:text-red-600 tracking-tight">Sign Out</span>
      <% end %>
   </div>
</aside>

<style>
   #sidebar {
      /* Subtle gradient that feels premium and clean */
      background: linear-gradient(180deg, #FFFFFF 0%, #F8FAFC 100%);
   }

   /* Smooth hover transition */
   .nav_item {
      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
   }
   
   .nav_item:hover:not(.bg-\[\#01003d\]) {
      transform: translateX(4px);
   }

   /* Custom Scrollbar for the brand */
   #sidebar::-webkit-scrollbar { width: 4px; }
   #sidebar::-webkit-scrollbar-thumb {
      background: #E2E8F0;
      border-radius: 10px;
   }

   .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 20;
   }
</style>