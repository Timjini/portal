    <div class="bg-gray-50 dark:bg-transparent dark:text-gray-200 p-5 rounded-lg">
      <h2 class="text-lg font-semibold text-gray-800 dark:text-gray-200 mb-4 pb-2 border-b border-gray-200"><%= title %></h2>
      <div class="space-y-3">
        <% data.each do |key,value|%>
        <div class="flex justify-between">
          <span class="text-gray-600 dark:text-gray-200 font-medium"><%= key %></span>
          <span class="text-gray-900 dark:text-gray-400"><%= value %></span>
        </div>
        <% end %>
      </div>
    </div>