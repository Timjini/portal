<div class="max-w-4xl 2xl:max-w-6xl mx-auto min-h-screen">
    <div class="dark:bg-slate-900 shadow-xl shadow-blue-900/5 overflow-hidden border border-gray-100 dark:border-gray-800">
        <div class="p-8">

            <div class="text-center mb-12">
                <h2 class="text-4xl font-black text-[#01003d] dark:text-white uppercase tracking-tighter">
                    Create a<span class="text-transparent" style="-webkit-text-stroke: 1px #01003d;"> new post</span>
                </h2>
                <div class="w-16 h-1 bg-[#01003d] mx-auto mt-4 rounded-full"></div>
                <p class="text-gray-500 mt-4 font-medium">This is a public feed</p>
            </div>
            <%= render "form", feed: @feed %>
        </div>
    </div>
</div>