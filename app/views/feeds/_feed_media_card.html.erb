<div class="max-w-xl mx-auto my-6 bg-white border border-gray-200 shadow-sm">
  
  <div class="flex items-center justify-between p-4">
    <div class="flex items-center space-x-3">
          <%= image_tag(feed.creator.avatar_thumbnail, class: "h-10 w-10 rounded-full object-cover shadow-2xl ") %>
      <div>
        <p class="text-sm font-bold text-gray-900 leading-tight">
          <%= feed.creator.username %>
        </p>
        <p class="text-xs text-gray-500">
          <%= time_ago_in_words(feed.created_at) %> ago
          <% if feed.feed_type == 'event' %> 
            • <span class="text-blue-600 font-semibold">Event</span>
          <% end %>
        </p>
      </div>
    </div>
    
    <%# More Options Icon %>
    <button class="text-gray-400 hover:text-gray-600">
      <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/></svg>
    </button>
  </div>

  <%# 2. Media Section: Full Width %>
  <div class="relative bg-gray-100 aspect-square sm:aspect-video flex items-center justify-center overflow-hidden border-y border-gray-100">
    <% case feed.feed_type %>
    <% when 'youtube' %>
      <% video_id = feed.url.match(/(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/)([^"&?\/\s]{11})/)[1] rescue nil %>
      <iframe class="w-full h-full" src="https://www.youtube.com/embed/<%= video_id %>?modestbranding=1&rel=0" frameborder="0" allowfullscreen></iframe>

    <% when 'video' %>
      <%= video_tag rails_blob_path(feed.media), controls: true, class: "w-full h-full object-cover" if feed.media.attached? %>

    <% when 'image', 'event' %>
      <%= image_tag feed.feed_thumbnail, class: "w-full h-full object-cover" %>
    <% end %>

    <%# Optional: Overlay for Event Date %>
    <% if feed.feed_type == 'event' && feed.event_date.present? %>
      <div class="absolute top-4 right-4 bg-white/90 backdrop-blur px-3 py-1 shadow-sm text-center border border-gray-200">
        <p class="text-[10px] uppercase font-black text-gray-500"><%= Date.parse(feed.event_date).strftime("%b") %></p>
        <p class="text-xl font-bold text-gray-900 -mt-1"><%= Date.parse(feed.event_date).strftime("%d") %></p>
      </div>
    <% end %>
  </div>

  <%# 3. Interaction Bar %>
  <div class="px-4 py-3">
    <div class="flex items-center justify-between mb-3">
      <div class="hidden items-center space-x-4">
        <button class="hover:scale-110 transition-transform text-gray-700"><svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg></button>
        <button class="hover:scale-110 transition-transform text-gray-700"><svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg></button>
        <button class="hover:scale-110 transition-transform text-gray-700"><svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"></path></svg></button>
      </div>
      <button class="text-gray-700 hidden"><svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"></path></svg></button>
    </div>

    <%# 4. Text Content %>
    <div class="space-y-1">
      <p class="text-sm">
        <span class="font-bold mr-2"><%= feed.creator.email.split('@').first %></span>
        <span class="text-gray-900 font-semibold"><%= feed.title %></span>
      </p>
      <p class="text-sm text-gray-600 leading-snug">
        <%= truncate(feed.description, length: 120) %>
        <% if feed.description.length > 120 %>
          <%= link_to "more", feed, class: "text-gray-400 font-medium" %>
        <% end %>
      </p>
    </div>

    <%# 5. Link / Action Button %>
    <% if feed.url.present? && feed.feed_type != 'youtube' %>
      <div class="mt-3">
        <%= link_to feed.url, target: "_blank", class: "block w-full text-center bg-gray-50 border border-gray-200 py-2 rounded-lg text-xs font-bold text-blue-600 hover:bg-blue-50 transition-colors" do %>
          Learn More
        <% end %>
      </div>
    <% end %>
  </div>
</div>