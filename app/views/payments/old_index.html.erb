<% plan = if current_user.role == 'parent_user' 
    current_user.children.first&.plan 
    else 
    current_user&.plan 
    end
%>
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- PAGE HEADER --->
    <%= render :partial => 'components/page_header', :locals => { title: 'Payments', description: 'Manage all Payments & Subscriptions'} %>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-12">
        <div class="lg:col-span-2">
            <h3 class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-4">Active Subscription</h3>
            <% if plan %>
            <div class="relative overflow-hidden bg-gradient-to-br from-indigo-600 to-blue-700 rounded-2xl p-8 shadow-xl text-white min-h-[220px]">
                <div class="absolute top-0 right-0 -mt-4 -mr-4 w-32 h-32 bg-white/10 rounded-full blur-3xl"></div>

                <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 relative z-10">
                    <div>
                        <span class="px-3 py-1 bg-white/20 rounded-full text-xs font-bold uppercase tracking-widest mb-3 inline-block">Current Plan</span>
                        <h2 class="text-2xl font-bold"><%= plan.name %></h2>
                        <p class="text-blue-100 opacity-90 text-sm mt-1 uppercase tracking-tight">Billed <%= plan.interval_unit %></p>
                    </div>
                    <div class="text-left md:text-right">
                        <p class="text-4xl font-black">
                            <%= "#{ "%.2f" % (plan.amount.round / 100.0) }" %>
                            <span class="text-lg font-medium opacity-80"><%= plan.currency %></span>
                        </p>
                        <p class="text-blue-100 text-sm">Renews automatically</p>
                    </div>
                </div>
            </div>
            <% else %>
                            <%= form_with url: '/payments', method: :post, data: { turbo: false }, class: "space-y-4" do |f| %>

            <div class="bg-gray-50 border-2 border-dashed border-gray-200 rounded-2xl p-8 text-center">
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-12">
                    <div class="lg:col-span-2">
                        <h3 class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-4">Available Plans</h3>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <% Plan.all.each do |p| %>
                            <div class="relative overflow-hidden bg-white border-2 <%= plan&.id == p.id ? 'border-indigo-600 ring-2 ring-indigo-100' : 'border-gray-100 hover:border-indigo-300' %> rounded-2xl p-6 shadow-sm transition-all">
                                <% if plan&.id == p.id %>
                                <div class="absolute top-0 right-0 bg-indigo-600 text-white text-[10px] font-bold px-3 py-1 rounded-bl-lg uppercase">
                                    Current
                                </div>
                                <% end %>

                                <div class="flex flex-col h-full justify-between">
                                    <div>
                                        <h2 class="text-xl font-bold text-gray-900"><%= p.name %></h2>
                                        <p class="text-gray-500 text-xs uppercase tracking-tight mb-4">Billed <%= p.interval_unit %></p>

                                        <p class="text-3xl font-black text-gray-900">
                                            <%= number_to_currency(p.amount / 100.0, unit: p.currency == "GBP" ? "£" : "$") %>
                                        </p>
                                    </div>

                                    <% if plan&.id != p.id %>
                                            <%= radio_button :plan_id , plan, checked: plan&.id, style: "display: none;", class: "option-radio"%>
                                    <%= button_to "Select Plan", '#', class: "mt-6 w-full py-2 px-4 bg-indigo-50 text-indigo-700 font-bold rounded-xl hover:bg-indigo-600 hover:text-white transition-colors text-sm" %>
                                    <% else %>
                                    <div class="mt-6 w-full py-2 px-4 bg-green-50 text-green-700 font-bold rounded-xl text-center text-sm border border-green-100">
                                        Active Plan
                                    </div>
                                    <% end %>
                                </div>
                            </div>
                            <% end %>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <div class="lg:col-span-1">
            <h3 class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-4">Make a Payment</h3>
            <div class="bg-white border border-gray-200 shadow-sm rounded-2xl p-6">
                <div>
                    <label class="block text-xs font-bold text-gray-700 uppercase mb-2">Select Athlete</label>
                    <% if current_user.role == 'parent_user' %>
                        <% if current_user.children.nil?%>
                            <%= f.select :athlete, current_user.children.map {|child| [child.full_name, child.id]}, {}, class: "block w-full rounded-xl border-gray-200 bg-gray-50 py-3 pl-4 pr-10 text-sm focus:border-indigo-500 focus:ring-indigo-500 transition-all" %>
                        <%else%>
                            <span> No kids </span>
                        <%end%>
                    <% else %>
                    <%= f.hidden_field :plan_id, value: plan.id %>
                    <%= f.hidden_field :athlete, value: current_user.id %>
                    <div class="py-3 px-4 bg-gray-50 rounded-xl border border-gray-100 text-sm text-gray-600">
                        Personal Account: <%= current_user.full_name %>
                    </div>
                    <% end %>
                </div>
                <%= f.submit "Pay for Subscription", class: "btn w-full" %>
                <p class="text-[10px] text-center text-gray-400 mt-2">Secure encrypted payment processing</p>
                <% end %>
                            <% end %>

            </div>
        </div>
    </div>

    <%= render 'payments/payment_history' , :locals => { :payments => @payments } %>
</section>