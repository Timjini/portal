<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end mb-10 gap-6">
        <%= render 'shared/page_header_with_nav', title:"Financial Center", description: "Subscription management & billing records" %>
    </div>
    <% if @payment_information[:current_plan].present? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
        
        <% Array(@payment_information[:current_plan]).flatten.each do |user| %>
            <div class="flex flex-col h-full">
                <% if user.respond_to?(:plan) && user.plan.present? %>
                    <%
                    status_styles = {
                        'active'     => { bg: 'bg-[#01003d]', text: 'text-blue-200', badge: 'bg-emerald-500 text-white', accent: 'border-blue-900' },
                        'pending'    => { bg: 'bg-orange-600', text: 'text-orange-100', badge: 'bg-white text-orange-600', accent: 'border-orange-500' },
                        'processing' => { bg: 'bg-slate-800', text: 'text-slate-300', badge: 'bg-blue-500 text-white', accent: 'border-slate-700' },
                        'cancelled'  => { bg: 'bg-gray-200', text: 'text-gray-500', badge: 'bg-gray-400 text-white', accent: 'border-gray-300' }
                    }[user.user_plan.status] || { bg: 'bg-gray-100', text: 'text-gray-400', badge: 'bg-gray-300 text-white', accent: 'border-gray-200' }
                    %>

                    <div class="relative overflow-hidden <%= status_styles[:bg] %> rounded-3xl p-8 shadow-2xl transition-all duration-300 hover:-translate-y-1 flex flex-col h-full">
                        <%# Decorative Brand Mark %>
                        <div class="absolute top-0 right-0 p-4 opacity-10">
                          <span class="material-symbols-outlined !text-[120px]">payments</span>
                        </div>
                        
                        <div class="relative z-10 flex-1">
                            <div class="flex justify-between items-start mb-10">
                                <span class="<%= status_styles[:badge] %> px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest shadow-sm">
                                    <%= user.user_plan.status %>
                                </span>
                                <div class="text-white/30">
                                  <span class="material-symbols-outlined">verified_user</span>
                                </div>
                            </div>
                            
                            <h2 class="text-2xl font-black text-white uppercase tracking-tighter leading-none"><%= user.plan.name %></h2>
                            <p class="<%= status_styles[:text] %> text-[10px] mt-2 uppercase tracking-[0.2em] font-black">
                                <%= user.plan.interval_unit %> Billed Access
                            </p>
                            
                            <div class="mt-8 flex items-baseline gap-2 text-white">
                                <span class="text-5xl font-black tracking-tighter"><%= number_to_currency(user.plan.amount / 100.0) %></span>
                                <span class="text-sm font-bold opacity-60 uppercase tracking-widest"><%= user.plan.currency %></span>
                            </div>
                        </div>

                        <%# Account Holder Module - Chambers Scout Style %>
                        <div class="mt-10 pt-6 border-t <%= status_styles[:accent] %> flex items-center gap-4 relative z-10">
                            <div class="h-10 w-10 rounded-xl bg-white/10 backdrop-blur-md flex items-center justify-center font-black text-xs text-white border border-white/20">
                                <%= user.full_name.split.map(&:first).join %>
                            </div>
                            <div>
                                <p class="text-[9px] uppercase tracking-widest text-white/50 font-black">Athletic Profile</p>
                                <p class="text-sm font-bold text-white tracking-tight"><%= user.full_name %></p>
                            </div>
                        </div>

                        <%# Action Area %>
                        <div class="mt-8 relative z-10">
                            <% case user.user_plan.status %>
                            <% when 'pending' %>
                                <%= button_to payments_path, method: :post, params: { athlete: user.id }, data: { turbo: false }, class: "w-full py-4 bg-white text-orange-600 font-black uppercase tracking-widest text-xs rounded-xl hover:shadow-xl transition-all flex items-center justify-center gap-2" do %>
                                    Complete Payment
                                    <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                                <% end %>
                            
                            <% when 'processing' %>
                                <div class="w-full py-4 bg-white/5 border border-white/20 rounded-xl text-center text-[10px] font-black uppercase tracking-[0.2em] text-white animate-pulse">
                                    Authenticating...
                                </div>

                            <% when 'active' %>
                                <div class="w-full py-4 bg-emerald-500/20 border border-emerald-500/40 rounded-xl text-center text-[10px] font-black uppercase tracking-[0.2em] text-emerald-400 flex items-center justify-center gap-2">
                                    <span class="material-symbols-outlined text-[16px]">check_circle</span>
                                    Subscription Active
                                </div>

                            <% when 'cancelled' %>
                                <%= button_to payments_path, method: :post, params: { athlete: user.id }, data: { turbo: false }, class: "w-full py-4 bg-[#01003d] text-white font-black uppercase tracking-widest text-xs rounded-xl hover:bg-slate-900 transition-all" do %>
                                    Reactivate Access
                                <% end %>
                            <% end %>
                        </div>
                    </div>

                <% else %>
                    <%# Plan Required Card - Scout Style %>
                    <div class="flex flex-col h-full bg-white dark:bg-slate-800 rounded-3xl p-8 border border-gray-100 dark:border-gray-700 shadow-xl shadow-blue-900/5 group hover:border-[#01003d] transition-all duration-300">
                        <div class="mb-auto">
                            <div class="h-14 w-14 bg-gray-50 dark:bg-slate-700 rounded-2xl flex items-center justify-center mb-8 border border-gray-100 dark:border-gray-600 group-hover:bg-[#01003d] transition-colors duration-300">
                                <span class="material-symbols-outlined text-gray-400 group-hover:text-white transition-colors">credit_card_off</span>
                            </div>
                            <h3 class="text-xl font-black text-[#01003d] dark:text-white uppercase tracking-tighter">Plan Required</h3>
                            <p class="text-sm text-gray-500 mt-4 leading-relaxed font-medium">
                                Account access for <span class="text-[#01003d] dark:text-white font-bold"><%= user.full_name %></span> is currently restricted. Select a development plan to unlock performance tracking.
                            </p>
                        </div>

                        <div class="mt-10">
                            <%= button_to subscriptions_path, method: :get, params: { user_id: user.id }, class: "btn-brand-primary w-full py-4 flex items-center justify-center gap-2" do %>
                                <span class="text-xs uppercase tracking-[0.15em]">Select Plan</span>
                                <span class="material-symbols-outlined text-[18px]">rocket_launch</span>
                            <% end %>
                            
                            <div class="mt-6 flex items-center justify-center gap-2 opacity-40">
                                <span class="material-symbols-outlined text-[14px]">lock</span>
                                <span class="text-[9px] font-black uppercase tracking-widest">Encrypted Checkout</span>
                            </div>
                        </div>
                    </div>
                <% end %>
            </div>
        <% end %>

    </div>
    <% end %>

    <%# Payment History Section %>
    <div class="mt-12 bg-white dark:bg-slate-900 rounded-3xl p-2 border border-gray-100 dark:border-gray-800 shadow-sm">
        <%= render 'payments/payment_history', payments: @payment_information[:payments] %>
    </div>
</section>