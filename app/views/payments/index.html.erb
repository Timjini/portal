<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <%= render :partial => 'components/page_header', :locals => { title: 'Payments', description: 'Manage billing and subscription plans'} %>

    <% if @payment_information[:current_plan].present? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
        
        <%# THE FIX: Array() ensures that even a single user object becomes an array you can loop through %>
        <% Array(@payment_information[:current_plan]).flatten.each do |user| %>
            <div class="flex flex-col">
                <% if user.respond_to?(:plan) && user.plan.present? %>
                    <div class="relative overflow-hidden bg-gradient-to-br from-indigo-600 to-blue-700 rounded-2xl p-8 shadow-xl text-white h-full flex flex-col justify-between transition-all hover:shadow-2xl">
                        <div class="absolute top-0 right-0 -mt-4 -mr-4 w-32 h-32 bg-white/10 rounded-full blur-3xl"></div>
                        <div class="relative z-10">
                            <div class="flex justify-between items-start mb-6">
                                <span class="px-2.5 py-1 bg-white/20 rounded-lg text-[10px] font-bold uppercase tracking-widest text-white border border-white/30 backdrop-blur-sm">Active Subscription</span>
                                <div class="p-1.5 bg-white/10 rounded-full">
                                    <svg class="w-5 h-5 text-blue-200" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zM10 5a1 1 0 00-1 1v3a1 1 0 001 1h3a1 1 0 100-2h-2V6a1 1 0 00-1-1z" clip-rule="evenodd" /></svg>
                                </div>
                            </div>
                            
                            <h2 class="text-2xl font-bold leading-tight tracking-tight"><%= user.plan.name %></h2>
                            <p class="text-blue-100 opacity-90 text-xs mt-1 uppercase tracking-widest font-semibold">Billed <%= user.plan.interval_unit %></p>
                            
                            <div class="mt-8 flex items-baseline gap-1">
                                <span class="text-4xl font-black tracking-tight"><%= number_to_currency(user.plan.amount / 100.0) %></span>
                                <span class="text-sm font-medium opacity-80 uppercase tracking-tighter"><%= user.plan.currency %></span>
                            </div>
                        </div>

                        <div class="mt-8 pt-6 border-t border-white/10 flex items-center gap-3 relative z-10">
                            <div class="h-9 w-9 rounded-full bg-white/20 flex items-center justify-center font-bold text-xs uppercase border border-white/20">
                                <%= user.full_name.split.map(&:first).join %>
                            </div>
                            <div>
                                <p class="text-[10px] uppercase tracking-tighter opacity-70 font-bold">Account Holder</p>
                                <p class="text-sm font-bold tracking-tight"><%= user.full_name %></p>
                            </div>
                        </div>
                    </div>

                <% else %>
                    <div class="flex flex-col h-full bg-white rounded-2xl p-8 border-2 border-dashed border-slate-200 shadow-sm transition-all hover:border-indigo-400 hover:shadow-md group">
                        <div class="mb-auto text-center md:text-left">
                            <div class="h-12 w-12 bg-slate-50 rounded-2xl flex items-center justify-center mb-6 border border-slate-100 group-hover:bg-indigo-50 transition-colors">
                                <svg class="w-6 h-6 text-slate-400 group-hover:text-indigo-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
                            </div>
                            <h3 class="text-xl font-bold text-slate-900 tracking-tight">Plan Required</h3>
                            <p class="text-sm text-slate-500 mt-3 leading-relaxed">
                                To activate features for <strong><%= user.full_name %></strong>, please choose a plan. You can cancel anytime.
                            </p>
                        </div>

                        <div class="mt-10">
                            <%= button_to subscriptions_path, method: :get, params: { user_id: user.id }, class: "w-full flex items-center justify-center gap-2 py-3.5 px-4 bg-red-700 text-white font-bold rounded-xl hover:bg-red-800 shadow-lg shadow-red-100 transition-all active:scale-[0.98]" do %>
                                <span>Get Started</span>
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                            <% end %>
                            
                            <div class="mt-4 flex items-center justify-center gap-1.5 grayscale opacity-60">
                                <svg class="w-3.5 h-3.5 text-slate-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" /></svg>
                                <span class="text-[11px] font-medium text-slate-500">Secure 256-bit SSL encryption</span>
                            </div>
                        </div>
                    </div>
                <% end %>
            </div>
        <% end %>

    </div>
    <% end %>

    <div class="mt-4">
        <%= render 'payments/payment_history', payments: @payment_information[:payments] %>
    </div>
</section>