<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- PAGE HEADER --->
    <%= render :partial => 'components/page_header', :locals => { title: 'Payments', description: 'Manage all Payments & Subscriptions'} %>

    <% if !@payment_information[:current_plan].nil?%>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-12">
        <% user = @payment_information[:current_plan].is_a?(Array) ? @payment_information[:current_plan].first : @payment_information[:current_plan] %>
        <% if user.present? %>
        <div class="lg:col-span-1">
            <% if !user.plan.nil?%>
            <div class="flex flex-col h-full justify-between">
                <div class="relative overflow-hidden bg-gradient-to-br from-indigo-600 to-blue-700 rounded-2xl p-8 shadow-xl text-white min-h-[220px]">
                    <div class="absolute top-0 right-0 -mt-4 -mr-4 w-32 h-32 bg-white/10 rounded-full blur-3xl"></div>

                    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 relative z-10">
                        <div>
                            <span class="px-3 py-1 bg-white/20 rounded-full text-xs font-bold uppercase tracking-widest mb-3 inline-block">Plan</span>
                            <h2 class="text-2xl font-bold"><%= user.plan.name %></h2>
                            <p class="text-blue-100 opacity-90 text-sm mt-1 uppercase tracking-tight">Billed <%= user.plan.interval_unit %></p>
                        </div>
                        <div class="text-left md:text-right">
                            <p class="text-4xl font-black">
                                <%= "#{ "%.2f" % (user.plan.amount.round / 100.0) }" %>
                                <span class="text-lg font-medium opacity-80"><%= user.plan.currency %></span>
                            </p>
                            <p class="text-blue-100 text-sm">Renews automatically</p>
                        </div>
                    </div>
                    <div class="mt-4">
                        <span class="px-3 py-1 bg-white/20 rounded-full text-xs font-bold uppercase tracking-widest mb-3 inline-block"> <%=user.full_name%> </span>
                    </div>
                </div>
            </div>
            <%else%>
            <div class="relative overflow-hidden bg-gradient-to-br from-red-600 to-red-700 rounded-2xl p-8 shadow-xl text-white min-h-[220px] flex flex-col justify-between">
                <div>
                    <p class="text-xl font-bold mb-4">Plan Required</p>
                    <span class="px-3 py-1 bg-white/20 rounded-full text-xs font-bold uppercase tracking-widest mb-3 inline-block"> <%=user.full_name%> </span>
                </div>
                <%= button_to "Subscribe" , subscriptions_url, method: :get , params: {user_id: user.id},  class:"btn bg-white text-red-600 font-semibold py-2 px-4 rounded-lg hover:bg-red-100 hover:text-gray-900 transition duration-150" %>
            </div>
            <%end%>
        </div>
        <%end%>
    </div>

    <%end%>

    <%= render 'payments/payment_history' , payments: @payment_information[:payments] %>
</section>