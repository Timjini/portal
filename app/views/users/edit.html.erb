<div class="max-w-5xl mx-auto px-4 py-10">
  <%= form_with model: @user, class: "space-y-8" do |form| %>
    <div class="bg-white dark:bg-slate-900 shadow-xl shadow-blue-900/5 overflow-hidden border border-gray-100 dark:border-gray-800">
      <% if @user.errors.any? %>
            <div id="form-errors" class="mb-6 bg-red-50 border-l-4 border-red-500 p-4 text-red-700">
                <p class="font-bold uppercase tracking-wide text-sm mb-2">
                <%= pluralize(@user.errors.count, "error") %> prohibited this account from being saved:
                </p>
                <ul class="list-disc list-inside text-sm">
                <% @user.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                <% end %>
                </ul>
            </div>
      <% end %>
      <div class="p-8 md:p-12 border-b border-gray-50 dark:border-gray-800">
        <div class="flex flex-col md:flex-row justify-between items-center gap-6">
          <div class="text-center md:text-left">
            <h2 class="text-3xl font-black text-[#01003d] dark:text-white uppercase tracking-tighter">
              <%= @user.athlete? ? "Athlete" : "User" %> <span class="text-transparent" style="-webkit-text-stroke: 1px #01003d;">Settings</span>
            </h2>
            <p class="text-gray-500 font-medium mt-1">Manage account security and performance vitals</p>
          </div>
          
          <% if current_user.admin? %>
            <div class="bg-blue-50 dark:bg-blue-900/20 px-6 py-3 rounded-2xl border border-blue-100 dark:border-blue-800/50">
              <label class="label-brand-caps text-blue-700 dark:text-blue-400 mb-2 block">System Role</label>
              <%= form.select :role, 
                  User::ROLE_TYPES.map { |k,v| [k.to_s.titleize, v] }, 
                  {}, 
                  class: "bg-transparent font-bold text-[#01003d] dark:text-white border-none focus:ring-0 p-0 text-sm" %>
            </div>
          <% end %>
        </div>
      </div>

      <div class="p-8 md:p-12 space-y-12">
        
        <div class="flex flex-col lg:flex-row gap-12 items-start">
          <div class="w-full lg:w-auto flex flex-col items-center" data-controller="avatar">
            <div class="relative group">
              <div class="w-36 h-36 rounded-full border-4 border-white shadow-2xl overflow-hidden bg-gray-50 ring-1 ring-gray-100 relative">
                <div data-loading-indicator-target="loadingIndicator" class="hidden absolute inset-0 flex items-center justify-center bg-white/80 z-10">
                  <%= render "shared/loading_spinner" %>
                </div>
                <div class="panzoom-container w-full h-full">
                  <%= image_tag(@user.avatar_thumbnail, id: "image", class: "w-full h-full object-cover", data: { avatar_target: "image" }) %>
                </div>
              </div>
              
              <label for="avatarInput" class="absolute bottom-1 right-1 p-3 bg-[#01003d] text-white rounded-full cursor-pointer shadow-lg hover:scale-110 transition-transform active:scale-95 z-20">
                <span class="material-symbols-outlined !text-[20px]">photo_camera</span>
              </label>
            </div>
            <div class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 mt-4">Profile Identity</div>
            <%= form.file_field :avatar, class: "hidden", id: "avatarInput", data: { avatar_target: "input", action: "change->avatar#handleFileSelect" } %>
          </div>

          <div class="flex-1 grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-8">
            <div class="space-y-1">
              <%= form.label :username, "Display Username", class: "label-brand-caps" %>
              <%= form.text_field :username, class: "input-brand-underline", required: true %>
            </div>
            <div class="space-y-1">
              <%= form.label :email, "Primary Email", class: "label-brand-caps" %>
              <%= form.email_field :email, class: "input-brand-underline", required: true %>
            </div>
            <div class="space-y-1">
              <%= form.label :first_name, "Legal First Name", class: "label-brand-caps" %>
              <%= form.text_field :first_name, class: "input-brand-underline", required: true %>
            </div>
            <div class="space-y-1">
              <%= form.label :last_name, "Legal Last Name", class: "label-brand-caps" %>
              <%= form.text_field :last_name, class: "input-brand-underline", required: true %>
            </div>
          </div>
        </div>

        <hr class="border-gray-50 dark:border-gray-800">

        <div>
          <div class="flex items-center gap-3 mb-8">
            <span class="p-2 bg-emerald-50 text-emerald-600 rounded-xl">
              <span class="material-symbols-outlined !text-[20px]">fitness_center</span>
            </span>
            <h3 class="text-sm font-black uppercase tracking-widest text-[#01003d] dark:text-white">Performance Vitals</h3>
          </div>

          <%= form.fields_for :athlete_profile  do |profile_form| %>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
              <div class="space-y-1">
                <%= profile_form.label :dob, "Date of Birth", class: "label-brand-caps" %>
                <%= profile_form.date_field :dob, class: "input-brand-underline", max: Date.today %>
              </div>
              <div class="space-y-1">
                <%= profile_form.label :school_name, "Academic Institution", class: "label-brand-caps" %>
                <%= profile_form.text_field :school_name, class: "input-brand-underline" %>
              </div>
              <div class="space-y-1">
                <%= profile_form.label :height, "Height (cm)", class: "label-brand-caps" %>
                <%= profile_form.number_field :height, class: "input-brand-underline", step: 0.1 %>
              </div>
              <div class="space-y-1">
                <%= profile_form.label :weight, "Weight (kg)", class: "label-brand-caps" %>
                <%= profile_form.number_field :weight, class: "input-brand-underline", step: 0.1 %>
              </div>

              <% if current_user.admin? %>
                <div class="md:col-span-2 lg:col-span-3 space-y-1">
                  <%= profile_form.label :power_of_ten, "Power of Ten URL", class: "label-brand-caps text-blue-600" %>
                  <%= profile_form.text_field :power_of_ten, class: "input-brand-underline border-blue-200", placeholder: "https://www.thepowerof10.info/..." %>
                </div>
                <div class="md:col-span-2 lg:col-span-1 space-y-1">
                  <%= profile_form.label :level, "Athlete Status", class: "label-brand-caps text-blue-600" %>
                  <%= profile_form.select :level, ['development', 'intermediate', 'advanced'], {}, class: "input-brand-underline" %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>

        <div class="pt-10 flex flex-col md:flex-row justify-end gap-4 border-t border-gray-50 dark:border-gray-800">
          <%= form.submit "Update Profile", 
              class: "btn-brand-primary w-full md:w-auto px-12 py-4", 
              data: { turbo_submits_with: "Syncing..." } %>
        </div>
      </div>
    </div>
  <% end %>
</div>