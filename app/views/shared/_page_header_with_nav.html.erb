 <% title_arr = title.split(' ') %>
 <div class="flex items-start gap-5">
     <%= render 'components/back_button' %>
     <div>
         <h1 class="text-4xl font-black text-[#01003d] uppercase tracking-tighter leading-none dark:text-gray-100">
            <%= title_arr[0] %>  <span class="pl-2 text-[#01003d] dark:text-gray-200 londrina-outline-regular text-5xl" ><%= title_arr[-1]%></span>
         </h1>
         <div class="w-12 h-1 bg-[#01003d] mt-3 rounded-full"></div>
         <p class="text-gray-500 mt-3 font-medium dark:text-gray-300"> <%= description %> </p>
     </div>
 </div>