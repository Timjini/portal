<div class="max-w-7xl pt-4 px-4 md:px-8">
    <div class="flex flex-wrap gap-2">
        <%= link_to feeds_path, class: "px-4 py-1 rounded-full text-sm font-semibold transition-colors duration-200 border #{request.path == feeds_path ? 'bg-gray-200 text-[#01003d] border-gray-300' : 'bg-[#01003d] text-gray-50 border-transparent hover:bg-gray-200 hover:text-[#01003d]'}" do %>
            Feed
        <% end %>

        <%= link_to exercises_path, class: "px-4 py-1 rounded-full text-sm font-semibold transition-colors duration-200 border #{request.path == exercises_path ? 'bg-gray-200 text-[#01003d] border-gray-300' : 'bg-[#01003d] text-gray-50 border-transparent hover:bg-gray-200 hover:text-[#01003d]'}" do %>
            Workouts
        <% end %>
    </div>
</div>