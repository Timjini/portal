<section class="grid grid-cols-1 lg:grid-cols-2 min-h-screen bg-gray-50 dark:bg-slate-950">
  
  <div class="relative hidden lg:flex flex-col justify-center items-start px-12 xl:px-24 overflow-hidden" style="background-color: #01003d;">
    <div class="absolute inset-0 opacity-10 pointer-events-none">
      <svg width="100%" height="100%"><rect width="100%" height="100%" fill="url(#grid)" /></svg>
    </div>

    <div class="relative z-10">
      <div class="mb-8">
         <%= image_tag("cfs-light.png", class: "h-16 w-auto", alt: "Chambers For Sport") %>
      </div>
      
      <h1 class="text-5xl xl:text-6xl font-black text-white leading-tight uppercase tracking-tighter">
        Update <br/> <span class="text-transparent" style="-webkit-text-stroke: 1px white;">Security</span>
      </h1>
      
      <div class="w-20 h-1 mt-6 bg-white"></div>

      <p class="mt-8 text-lg text-blue-100/80 max-w-md font-light leading-relaxed">
        Ensure your account stays protected with a strong, updated password.
      </p>
    </div>
  </div>

  <div class="flex flex-col justify-center px-6 py-12 lg:px-20 xl:px-32">
    <div class="sm:mx-auto sm:w-full sm:max-w-md">
      <div class="lg:hidden flex justify-center mb-10">
         <%= image_tag("cfs-dark.png", class: "h-12 w-auto") %>
      </div>
      <h2 class="text-4xl font-extrabold tracking-tight text-gray-900 dark:text-white" style="color: #01003d;">
        Reset Password
      </h2>
      <p class="mt-2 text-sm text-gray-500">
        Enter your new credentials below.
      </p>
    </div>

    <div class="mt-10 sm:mx-auto sm:w-full sm:max-w-md">
      <div class="bg-white dark:bg-gray-900">
        
        <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>
          <%= f.hidden_field :reset_password_token %>

          <div data-controller="visibility">
            <div class="flex justify-between items-end">
              <%= f.label :password, "New Password", class: "label-brand-caps" %>
              <% if @minimum_password_length %>
                <span class="text-[10px] text-gray-400 mb-1">(<%= @minimum_password_length %> chars min)</span>
              <% end %>
            </div>
            <div class="relative">
              <%= f.password_field :password, autofocus: true, autocomplete: "new-password", 
                    placeholder: "••••••••",
                    class: "input-brand-underline pr-10",
                    data: { visibility_target: "password" } %>
              
              <button type="button" class="absolute bottom-3 right-0 text-gray-400 hover:text-[#01003d]" data-action="click->visibility#toggleVisibility">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
              </button>
            </div>
          </div>

          <div>
            <%= f.label :password_confirmation, "Confirm New Password", class: "label-brand-caps" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", 
                  placeholder: "••••••••",
                  class: "input-brand-underline" %>
          </div>

          <div class="pt-4">
            <%= f.submit "Update Password", 
                class: "btn-brand-primary w-full" %>
          </div>
        <% end %>

        <div class="mt-12 text-center border-t border-gray-100 pt-8 dark:border-gray-700">
          <div class="flex flex-col gap-3">
            <%= render "devise/shared/links" %>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>