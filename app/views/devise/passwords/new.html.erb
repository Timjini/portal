<section class="grid grid-cols-1 lg:grid-cols-2 min-h-screen bg-gray-50 dark:bg-slate-950 w-full">
  
  <div class="relative hidden lg:flex flex-col justify-center items-start px-12 xl:px-24 overflow-hidden" style="background-color: #01003d;">
    <div class="absolute inset-0 opacity-10 pointer-events-none">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="1"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)" />
      </svg>
    </div>

    <div class="relative z-10">
      <div class="mb-8">
         <%= image_tag("cfs-light.png", class: "h-16 w-auto", alt: "Chambers For Sport") %>
      </div>
      
      <h1 class="text-5xl xl:text-6xl font-black text-white leading-tight uppercase tracking-tighter">
        Secure Your <br/> <span class="text-transparent" style="-webkit-text-stroke: 1px white;">Account</span>
      </h1>
      
      <div class="w-20 h-1 mt-6 "></div> <p class="mt-8 text-lg text-blue-100/80 max-w-md font-light leading-relaxed">
        Let's get you back on track to elite performance.
      </p>
    </div>
  </div>

  <div class="flex flex-col justify-center px-6 py-12 lg:px-20 xl:px-32">
    <div class="sm:mx-auto sm:w-full sm:max-w-md">
      <div class="lg:hidden flex justify-center mb-10">
         <%= image_tag("cfs-dark.png", class: "h-12 w-auto") %>
      </div>
      <h2 class="text-4xl font-extrabold tracking-tight text-gray-900 dark:text-white" style="color: #01003d;">
        Forgot Password?
      </h2>
      <p class="mt-2 text-sm text-gray-500">
        Enter your email address and we'll send you instructions to reset your password.
      </p>
    </div>

    <div class="mt-10 sm:mx-auto sm:w-full sm:max-w-md">
      <div class=" dark:bg-gray-900 py-10 px-0 sm:px-0">
        
        <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-6" }) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>

          <div>
            <%= f.label :email, class: "label-brand-caps" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", 
                  placeholder: "email@chambers.com",
                  class: "input-brand-underline" %>
          </div>

          <div class="pt-4">
            <%= f.submit "Send Reset Instructions", 
                class: "btn-brand-primary w-full" %>
          </div>
        <% end %>

        <div class="mt-12 text-center border-t border-gray-100 pt-8 dark:border-gray-700">
          <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">
            Remember your password? 
            <%= link_to "Sign In", new_session_path(resource_name), class: "ml-1 underline underline-offset-4 decoration-2 hover:text-black transition-colors", style: "color: #01003d;" %>
          </p>
        </div>

      </div>
    </div>
  </div>
</section>