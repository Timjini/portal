<section class="grid grid-cols-1 lg:grid-cols-2 min-h-screen bg-gray-50 dark:bg-slate-950 w-full" >
  
  <div class="relative hidden lg:flex flex-col justify-center items-start px-12 xl:px-24 overflow-hidden bg-[#01003d]">
    
    <div class="absolute inset-0 opacity-10 pointer-events-none">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="1"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)" />
      </svg>
    </div>

    <div class="relative z-10">
      <div class="mb-8">
         <%= image_tag("cfs-light.png", class: "h-36 w-auto", alt: "Chambers For Sport") %>
      </div>
      
      <h1 class="text-5xl xl:text-6xl font-black text-white leading-tight uppercase tracking-tighter">
        Chambers <br/> <span class="text-transparent" style="-webkit-text-stroke: 1px white;">For Sport</span>
      </h1>
      
      <div class="w-20 h-1 mt-6"></div> 
      <p class="mt-8 text-lg text-blue-100/80 max-w-md font-light leading-relaxed">
      </p>

      <div class="mt-16">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-blue-300/60 mb-6">Partners</p>
        <div class="flex flex-wrap gap-8 opacity-50 hover:opacity-100 transition-opacity duration-500">
          <div class="h-6 w-20 border border-white/30 rounded"></div> 
          <div class="h-6 w-20 border border-white/30 rounded"></div>
          <div class="h-6 w-20 border border-white/30 rounded"></div>
        </div>
      </div>
    </div>
  </div>

  <div class="flex flex-col justify-center px-6 py-6 md:py-2 lg:px-20 xl:px-32">
    <div class="space-y-6 px-4 sm:mx-auto sm:w-full sm:max-w-md">
      <div class="lg:hidden flex justify-center mb-2 md:mb-10">
         <%= image_tag("cfs-dark.png", class: "h-24 md:h-36 w-auto") %>
      </div>
      <h2 class="text-xl md:text-4xl font-extrabold tracking-tight text-[#01003d] dark:text-gray-100">
        Sign In
      </h2>
      <p class="mt-2 text-xs md:text-sm text-gray-500">
        Enter your credentials to manage your account.
      </p>
    </div>

    <div class="mt-0 md:mt-10 sm:mx-auto sm:w-full sm:max-w-md">
      <div class=" dark:bg-gray-900 py-0 md:py-0 px-0 sm:px-0">
        
        <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6 p-4" }) do |f| %>
          
          <div>
            <%= f.label :email_or_username, class: "block text-xs font-bold uppercase tracking-widest text-gray-400 mb-2" %>
            <%= f.text_field :email, autofocus: true, placeholder: "email@chambers.com", 
                class: "input-brand-underline" %>
          </div>

          <div data-controller="visibility">
            <div class="flex justify-between items-center">
              <%= f.label :password, class: "block text-xs font-bold uppercase tracking-widest text-gray-400 mb-2" %>
            </div>
            <div class="relative">
              <%= f.password_field :password, autocomplete: "current-password", placeholder: "••••••••", 
                  class: "block w-full rounded-none border-0 border-b-2 border-gray-200 bg-transparent px-0 py-3 text-gray-900 focus:border-[#01003d] focus:ring-0 sm:text-sm transition-colors dark:text-white dark:border-gray-700",
                  data: { visibility_target: "password" } %>
              <div class="absolute inset-y-0 right-0 flex items-center cursor-pointer" data-action="click->visibility#toggleVisibility">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
              </div>
            </div>
          </div>

          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <%= f.check_box :remember_me, class: "h-4 w-4 border-gray-300 rounded focus:ring-0", style: "color: #01003d;" %>
              <%= f.label :remember_me, class: "ml-2 block text-xs font-medium text-gray-500" %>
            </div>
            <%= link_to "Forgot password?", new_password_path(resource_name), class: "text-xs font-bold uppercase tracking-tighter hover:opacity-70 transition-opacity", style: "color: #01003d;" %>
          </div>

          <div class="pt-4">
           <%= f.submit "Access Platform", class: "btn-brand-primary w-full" , data: { turbo_submits_with: "Loading..." }  %>
          </div>
        <% end %>

        <% if devise_mapping.registerable? %>
          <div class="mt-2 md:mt-12 text-center">
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">
              New to the platform? 
              <%= link_to "Create Account", new_registration_path(resource_name), class: "ml-1 underline underline-offset-4 decoration-2 hover:text-black transition-colors text-[#01003d] dark:text-gray-100"%>
            </p>
          </div>
        <% end %>

      </div>
    </div>
  </div>
</section>