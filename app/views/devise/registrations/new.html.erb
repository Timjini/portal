<section class="grid grid-cols-1 lg:grid-cols-2 min-h-screen bg-gray-50 dark:bg-slate-950 w-full">

    <div class="relative hidden lg:flex flex-col justify-center items-start px-12 xl:px-24 overflow-hidden" style="background-color: #01003d;">
        <div class="absolute inset-0 opacity-10 pointer-events-none">
            <svg width="100%" height="100%">
                <rect width="100%" height="100%" fill="url(#grid)" />
            </svg>
        </div>
        <div class="relative z-10">
            <h1 class="text-5xl xl:text-6xl font-black text-white leading-tight uppercase tracking-tighter">
                Join the <br /> <span class="text-transparent" style="-webkit-text-stroke: 1px white;">Academy</span>
            </h1>
            <div class="w-20 h-1 mt-6 bg-white"></div>
            <p class="mt-8 text-lg text-blue-100/80 max-w-md font-light">Complete your profile to access the Chambers ecosystem.</p>
        </div>
    </div>

    <div class="flex flex-col justify-center px-6 py-12 lg:px-12 xl:px-24">
        <div class="sm:mx-auto sm:w-full sm:max-w-2xl">
            <%= form_for(resource, as: resource_name, url: registration_path(resource_name), data: { controller: "signup-validation" }) do |form| %>

            <div class="flex items-center justify-between mb-12 max-w-xs mx-auto">
                <div class="flex flex-col items-center gap-2">
                    <button type="button" class="w-10 h-10 rounded-full font-bold transition-all duration-300" style="background-color: #01003d; color: white;" data-signup-validation-target="step1Indicator" data-action="click->signup-validation#goToStep1">1</button>
                    <span class="text-[10px] uppercase font-bold tracking-widest text-gray-400">Personal</span>
                </div>
                <div class="flex-1 h-[2px] mx-4 bg-gray-200 dark:bg-gray-800 self-center -mt-6"></div>
                <div class="flex flex-col items-center gap-2">
                    <button type="button" class="w-10 h-10 rounded-full font-bold border-2 border-gray-200 text-gray-400 transition-all duration-300" data-signup-validation-target="step2Indicator" data-action="click->signup-validation#goToStep2">2</button>
                    <span class="text-[10px] uppercase font-bold tracking-widest text-gray-400">Details</span>
                </div>
            </div>

            <div class="" data-signup-validation-target="step1">
                <div class="mb-10 text-center" data-controller="avatar">
                    <div class="mx-auto w-32 h-32 mb-6 relative group">
                        <div class="panzoom-container absolute inset-0 overflow-hidden rounded-full border-4 border-white shadow-xl ring-1 ring-gray-200">
                            <img id="image" class="w-full h-full object-cover" src="/assets/user.png" data-avatar-target="image">
                        </div>
                        <label for="avatarInput" class="absolute bottom-0 right-0 p-2 bg-[#01003d] text-white rounded-full cursor-pointer shadow-lg hover:scale-110 transition-transform">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                        </label>
                    </div>
                    <%= form.file_field :avatar, class: "hidden", id: "avatarInput", data: { avatar_target: "input" } %>
                </div>

                <div class="grid grid-cols-1 gap-x-8 gap-y-6 sm:grid-cols-2">
                    <div>
                        <%= form.label :email, class: "label-brand-caps" %>
                        <%= form.email_field :email, class: "input-brand-underline", placeholder: "you@example.com", data: { signup_validation_target: "email", field_name: "email", action: "input->signup-validation#validateField blur->signup-validation#markAsTouched" } %>
                        <p class="mt-2 text-[10px] font-bold uppercase text-red-500 hidden" data-signup-validation-target="emailError"></p>
                    </div>

                    <div>
                        <%= form.label :username, class: "label-brand-caps" %>
                        <%= form.text_field :username, class: "input-brand-underline", placeholder: "username123", data: { signup_validation_target: "username", field_name: "username", action: "input->signup-validation#validateField blur->signup-validation#markAsTouched" } %>
                        <p class="mt-2 text-[10px] font-bold uppercase text-red-500 hidden" data-signup-validation-target="usernameError"></p>
                    </div>

                    <div>
                        <%= form.label :first_name, class: "label-brand-caps" %>
                        <%= form.text_field :first_name, class: "input-brand-underline", placeholder: "John", data: { signup_validation_target: "firstName", field_name: "firstName", action: "input->signup-validation#validateField blur->signup-validation#markAsTouched" } %>
                        <p class="mt-1 text-sm text-red-600 hidden" data-signup-validation-target="firstNameError"></p>
                    </div>

                    <div>
                        <%= form.label :last_name, class: "label-brand-caps" %>
                        <%= form.text_field :last_name, class: "input-brand-underline", placeholder: "Doe", data: { signup_validation_target: "lastName", field_name: "lastName", action: "input->signup-validation#validateField blur->signup-validation#markAsTouched" } %>
                        <p class="mt-1 text-sm text-red-600 hidden" data-signup-validation-target="lastNameError"></p>
                    </div>

                    <div class="relative">
                        <%= form.password_field :password, autocomplete: "current-password", placeholder: "••••••••", 
                            class: "block w-full rounded-none border-0 border-b-2 border-gray-200 bg-transparent px-0 py-3 text-gray-900 focus:border-[#01003d] focus:ring-0 sm:text-sm transition-colors dark:text-white dark:border-gray-700",
                            data: { 
                                signup_validation_target: "password", 
                                field_name: "password", 
                                action: "input->signup-validation#validateField blur->signup-validation#markAsTouched" 
                            } %>
                        <div class="absolute inset-y-0 right-0 flex items-center cursor-pointer" data-action="click->signup-validation#togglePasswordVisibility" data-field-type="password">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                        </div>
                        <p class="mt-1 text-sm text-red-600 hidden" data-signup-validation-target="passwordError"></p>
                    </div>

                    <div class="relative">
                        <%= form.password_field :password_confirmation, autocomplete: "current-password", placeholder: "••••••••", 
                            class: "block w-full rounded-none border-0 border-b-2 border-gray-200 bg-transparent px-0 py-3 text-gray-900 focus:border-[#01003d] focus:ring-0 sm:text-sm transition-colors dark:text-white dark:border-gray-700",
                            data: {   "signup-validation-target": "passwordConfirmation",
                            "field-name": "passwordConfirmation",
                            "action": "input->signup-validation#validateField blur->signup-validation#markAsTouched"  } %>
                        <div class="absolute inset-y-0 right-0 flex items-center cursor-pointer" data-action="click->signup-validation#togglePasswordVisibility" data-field-type="passwordConfirmation">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                        </div>
                        <p class="mt-1 text-sm text-red-600 hidden" data-signup-validation-target="passwordConfirmationError"></p>
                    </div>
                </div>

                <div class="mt-10 flex flex-col gap-4">
                    <button type="button" class="next-step-btn btn-brand-primary w-full disabled:opacity-50 disabled:cursor-not-allowed" data-action="click->signup-validation#nextStep" data-signup-validation-target="nextButton" disabled>
                        Next: Professional Details
                    </button>
                    <%= link_to "Back to Sign In", new_session_path(resource_name), class: "text-center text-xs font-bold uppercase tracking-widest text-gray-400 hover:text-black" %>
                </div>
            </div>

            <div class="hidden" data-signup-validation-target="step2">
                <div class="grid grid-cols-1 gap-x-8 gap-y-6 sm:grid-cols-2">
                    <div>
                        <%= form.label :phone, class: "label-brand-caps" %>
                        <%= form.text_field :phone, class: "input-brand-underline", placeholder: "+1...", data: { signup_validation_target: "phone", field_name: "phone", action: "input->signup-validation#validateField blur->signup-validation#markAsTouched" } %>
                        <p class="mt-1 text-sm text-red-600 hidden" data-signup-validation-target="phoneError"></p>
                    </div>

                    <div data-controller="address-autocomplete" data-address-autocomplete-api-key-value="<%= ENV['GOOGLE_API_KEY'] %>">
                        <%= form.label :address, class: "label-brand-caps" %>
                        <%= form.text_field :address, class: "input-brand-underline", placeholder: "123 Street...", data: { address_autocomplete_target: "input", action: "place_changed->address-autocomplete#placeSelected input->signup-validation#validateField blur->signup-validation#markAsTouched", signup_validation_target: "address", field_name: "address" } %>
                        <p class="mt-1 text-sm text-red-600 hidden" data-signup-validation-target="addressError"></p>
                    </div>

                    <div>
                        <%= form.label :dob, "Date of Birth", class: "label-brand-caps" %>
                        <%= form.date_field :dob, class: "input-brand-underline", data: { signup_validation_target: "dob", field_name: "dob", action: "change->signup-validation#validateField blur->signup-validation#markAsTouched" } %>
                        <p class="mt-1 text-sm text-red-600 hidden" data-signup-validation-target="dobError"></p>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">I am</label>
                        <div class="mt-2 space-y-2" data-action="change->signup-validation#validateField click->signup-validation#markAsTouched">
                            <div class="flex items-center">
                                <%= form.radio_button :role, 'parent_user', 
                                checked: false,
                                class: "h-4 w-4 border-gray-300 text-indigo-600 focus:ring-indigo-500 dark:border-gray-600 dark:bg-gray-700",
                                data: { 
                                    "signup-validation-target": "role",
                                    "field-name": "role"
                                } %>
                                <%= form.label :parent_user, "a Parent of an Athlete(s)", class: "ml-2 block text-sm text-gray-900 dark:text-gray-300" %>
                            </div>
                            <div class="flex items-center">
                                <%= form.radio_button :role, 'athlete', 
                                checked: false,
                                class: "h-4 w-4 border-gray-300 text-indigo-600 focus:ring-indigo-500 dark:border-gray-600 dark:bg-gray-700",
                                data: { 
                                    "signup-validation-target": "role",
                                    "field-name": "role"
                                } %>
                                <%= form.label :athlete, "an Athlete", class: "ml-2 block text-sm text-gray-900 dark:text-gray-300" %>
                            </div>
                        </div>
                        <p class="mt-1 text-sm text-red-600 hidden" data-signup-validation-target="roleError"></p>
                    </div>
                </div>

                <div class="mt-6 flex items-center justify-between">
                    <button type="button" class="btn-brand-secondary" data-action="click->signup-validation#prevStep">
                        Previous
                    </button>
                    <%= form.submit "Create Account", 
                    class: "btn-brand-primary disabled:opacity-50 disabled:cursor-not-allowed",
                    data: { "signup-validation-target": "submitButton" },
                    disabled: true %>
                </div>
            </div>
            <% end %>
        </div>
    </div>
</section>