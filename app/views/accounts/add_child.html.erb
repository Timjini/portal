<div class="max-w-4xl mx-auto px-4 py-8">
  <%= render 'components/back_button' %>

  <div class="mt-8 bg-white dark:bg-slate-900 shadow-xl shadow-blue-900/5 overflow-hidden border border-gray-100 dark:border-gray-800">
    <div class="p-8 md:p-12">
      
      <div class="text-center mb-12">
        <h2 class="text-4xl font-black text-[#01003d] dark:text-white uppercase tracking-tighter">
          Register <span class="text-transparent" style="-webkit-text-stroke: 1px #01003d;">Child Athlete</span>
        </h2>
        <div class="w-16 h-1 bg-[#01003d] mx-auto mt-4 rounded-full"></div>
        <p class="text-gray-500 mt-4 font-medium">Initialize their professional development profile</p>
      </div>

      <%= form_with url: create_child_user_accounts_path(format: :html), method: :post, 
          html: { id: "account-form", class: "space-y-10" }, 
          data: {
            controller: "child-create",
            action: "submit->child-create#handleSubmit",
            "child-create-url-value": create_child_user_accounts_path(format: :json),
            "child-create-redirect-value": root_path
          } do |form| %>

        <div id="form-errors" class="hidden mb-6 bg-red-50 border-l-4 border-red-500 p-4 text-red-700 text-sm font-bold uppercase tracking-wide"></div>

        <div class="mb-12 text-center" data-controller="avatar">
          <div class="mx-auto w-36 h-36 relative group">
            <div class="panzoom-container absolute inset-0 overflow-hidden rounded-full border-4 border-white shadow-2xl ring-1 ring-gray-100 bg-gray-50">
               <%# Using the more sympathetic image we generated earlier %>
               <%= image_tag "user.png", id: "image", class: "w-full h-full object-cover", 
                            alt: "Avatar Preview", data: { avatar_target: "image" } %>
               <div data-loading-indicator-target="loadingIndicator" class="loading-indicator hidden absolute inset-0 flex items-center justify-center bg-white/80">
                 <%= render "shared/loading_spinner" %>
               </div>
            </div>
            
            <label for="avatarInput" class="absolute bottom-1 right-1 p-3 bg-[#01003d] text-white rounded-full cursor-pointer shadow-lg hover:scale-110 transition-transform active:scale-95">
              <%= render "icons/camera" %>
            </label>
          </div>
          <div class="text-[10px] font-black uppercase tracking-widest text-gray-400 mt-4">Profile Picture</div>
          
          <%= form.file_field :avatar, id: "avatarInput", class: "hidden", 
                              accept: "image/*", 
                              data: { 
                                avatar_target: "input", 
                                action: "change->avatar#handleFileSelect" 
                              } %>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
          
          <div class="space-y-8">
            <div>
              <%= form.label :username, "Athlete Username", class: "label-brand-caps" %>
              <%= form.text_field :username, class: "input-brand-underline", placeholder: "@athlete_name", required: true %>
            </div>

            <div>
              <%= form.label :first_name, class: "label-brand-caps" %>
              <%= form.text_field :first_name, class: "input-brand-underline", placeholder: "First Name", required: true %>
            </div>

            <div>
              <%= form.label :last_name, class: "label-brand-caps" %>
              <%= form.text_field :last_name, class: "input-brand-underline", placeholder: "Last Name", required: true %>
            </div>
          </div>

          <div class="space-y-8">
            <div>
              <%= form.label :dob, "Date of Birth", class: "label-brand-caps" %>
              <%= form.date_field :dob, class: "input-brand-underline", required: true %>
            </div>

            <div>
              <%= form.label :school_name, "Academic Institution", class: "label-brand-caps" %>
              <%= form.text_field :school_name, class: "input-brand-underline", placeholder: "Current School" %>
            </div>

            <div class="grid grid-cols-2 gap-6">
              <div>
                <%= form.label :height, "Height (cm)", class: "label-brand-caps" %>
                <%= form.number_field :height, class: "input-brand-underline", placeholder: "160" %>
              </div>
              <div>
                <%= form.label :weight, "Weight (kg)", class: "label-brand-caps" %>
                <%= form.number_field :weight, class: "input-brand-underline", placeholder: "55" %>
              </div>
            </div>
          </div>
        </div>

        <div class="pt-4" data-controller="visibility">
          <%= form.label :password, "Account Password", class: "label-brand-caps" %>
          <div class="relative">
            <%= form.password_field :password, placeholder: "••••••••", 
                                    class: "input-brand-underline pr-12",
                                    data: { visibility_target: "password" } %>
            <button type="button" class="absolute bottom-3 right-0 p-1 text-gray-400 hover:text-[#01003d] transition-colors" data-action="click->visibility#toggleVisibility">
              <%= render "icons/eye" %>
            </button>
          </div>
        </div>

        <div class="pt-6">
          <%= form.submit "Deploy Athlete Account", 
                          data: { child_create_target: "submit", turbo_submits_with: "Creating Account..." },
                          class: "btn-brand-primary w-full md:w-auto md:px-12 py-4" %>
        </div>
      <% end %>
      
    </div>
  </div>
</div>