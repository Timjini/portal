<div class="max-w-5xl mx-auto bg-white dark:bg-slate-900 rounded-3xl shadow-xl shadow-blue-900/5 overflow-hidden border border-gray-100 dark:border-gray-800">
  <div class="p-6 md:p-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
      
      <div class="flex flex-col items-center w-full lg:w-auto shrink-0">
        <div class="relative">
          <div class="w-40 h-40 rounded-full border-4 border-white shadow-2xl overflow-hidden bg-gray-50 ring-1 ring-gray-100">
            <%= image_tag(@athlete.user.avatar_thumbnail, class: "w-full h-full object-cover", alt: "Athlete Profile") %>
          </div>
          
          <% if @athlete.user.answers.any?(&:health_issue?) %>
            <div class="absolute top-2 right-2 group">
              <div class="bg-red-600 text-white p-2 rounded-xl shadow-lg cursor-help animate-pulse">
                <span class="material-symbols-outlined !text-[20px]">warning</span>
              </div>
              <div class="absolute z-20 left-1/2 -translate-x-1/2 top-full mt-3 w-56 bg-[#01003d] rounded-2xl shadow-2xl p-4 hidden group-hover:block transition-all">
                <div class="absolute -top-1 left-1/2 -translate-x-1/2 w-3 h-3 bg-[#01003d] rotate-45"></div>
                <h4 class="font-black text-[10px] uppercase tracking-widest text-red-400 mb-2">Medical Advisory</h4>
                <ul class="space-y-1.5">
                  <% @athlete.user_illnesses.each do |illness| %>
                    <li class="text-white text-xs font-medium flex items-center gap-2">
                      <span class="w-1 h-1 bg-red-400 rounded-full"></span>
                      <%= illness %>
                    </li>
                  <% end %>
                </ul>
              </div>
            </div>
          <% end %>
        </div>
        
        <div class="mt-6 text-center">
          <h3 class="text-2xl font-black text-[#01003d] dark:text-white uppercase tracking-tighter">
            <%= @athlete.user.username %>
          </h3>
          <div class="mt-2 inline-flex items-center px-4 py-1 rounded-full text-[10px] font-black uppercase tracking-[0.15em] shadow-sm
                      <%= @athlete.user.level&.downcase == 'development' ? 'bg-[#01003d] text-white' : 
                          @athlete.user.level&.downcase == 'intermediate' ? 'bg-blue-600 text-white' : 
                          'bg-emerald-500 text-white' %>">
            <%= @athlete.user.level %> Rank
          </div>
          <div class="mt-4">
            <%= render 'athlete_profiles/player_score' %>
          </div>
        </div>
      </div>
      
      <div class="flex-1 w-full grid grid-cols-1 md:grid-cols-3 gap-4 lg:gap-6">
        
        <div class="bg-gray-50/50 dark:bg-slate-800/50 p-5 rounded-2xl border border-gray-100 dark:border-gray-700">
          <h4 class="label-brand-caps flex items-center mb-5">
            <span class="material-symbols-outlined mr-2 !text-blue-500 !text-[18px]">badge</span>
            Athlete Bio
          </h4>
          <div class="space-y-4">
            <div class="flex flex-col">
              <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Full Name</span>
              <span class="text-sm font-bold text-[#01003d] dark:text-white"><%= @athlete.user&.full_name %></span>
            </div>
            <div class="flex justify-between items-end border-b border-gray-100 dark:border-gray-700 pb-1">
              <span class="text-[10px] font-bold text-gray-400 uppercase">Age</span>
              <span class="text-sm font-black text-[#01003d] dark:text-white"><%= @athlete.age %></span>
            </div>
            <div class="flex justify-between items-end border-b border-gray-100 dark:border-gray-700 pb-1">
              <span class="text-[10px] font-bold text-gray-400 uppercase">School</span>
              <span class="text-sm font-black text-[#01003d] dark:text-white"><%= @athlete.school_name.presence || "N/A" %></span>
            </div>
          </div>
        </div>
        
        <div class="bg-gray-50/50 dark:bg-slate-800/50 p-5 rounded-2xl border border-gray-100 dark:border-gray-700">
          <h4 class="label-brand-caps flex items-center mb-5">
            <span class="material-symbols-outlined mr-2 !text-emerald-500 !text-[18px]">straighten</span>
            Physicals
          </h4>
          <div class="space-y-4">
            <div class="flex justify-between items-end border-b border-gray-100 dark:border-gray-700 pb-1">
              <span class="text-[10px] font-bold text-gray-400 uppercase">Height</span>
              <span class="text-sm font-black text-[#01003d] dark:text-white"><%= @athlete.height.present? ? "#{@athlete.height}cm" : "N/A" %></span>
            </div>
            <div class="flex justify-between items-end border-b border-gray-100 dark:border-gray-700 pb-1">
              <span class="text-[10px] font-bold text-gray-400 uppercase">Weight</span>
              <span class="text-sm font-black text-[#01003d] dark:text-white"><%= @athlete.weight.present? ? "#{@athlete.weight}kg" : "N/A" %></span>
            </div>
            <div class="flex flex-col pt-1">
              <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Power of 10</span>
              <span class="text-sm font-black text-blue-600"><%= @athlete.power_of_ten.presence || "NOT LINKED" %></span>
            </div>
          </div>
        </div>
        
        <div class="bg-[#01003d] p-5 rounded-2xl shadow-xl shadow-blue-900/20">
          <h4 class="text-[10px] font-black uppercase tracking-widest text-blue-300 flex items-center mb-5">
            <span class="material-symbols-outlined mr-2 text-yellow-400 text-[18px]">stars</span>
           <span class="text-white"> Personal Bests </span>
          </h4>
          <div class="space-y-3">
            <% [["60m", "-"], ["100m", "-"], ["200m", "-"], ["Vertical", "-"]].each do |event, score| %>
              <div class="flex justify-between items-center bg-white/5 rounded-lg px-3 py-2">
                <span class="text-[10px] font-bold text-blue-100 uppercase"><%= event %></span>
                <span class="text-xs font-black text-white"><%= score %></span>
              </div>
            <% end %>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>