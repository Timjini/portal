modules = ["bun-1.1", "nodejs-20", "ruby-3.2", "web", "postgresql-17"]
run = "node index.js"

[nix]
channel = "stable-24_05"
packages = [
  "rubyPackages_3_2.railties",
  "rubyPackages_3_2.psych",
  "libyaml",
  "postgresql",
  "zlib",
  "gmp",
  "rbenv",
  "nodejs-20_x",
  "docker-compose",
  "docker_26",
]

[deployment]
run = ["sh", "-c", "node index.js"]
